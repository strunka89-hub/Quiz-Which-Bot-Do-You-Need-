# URL, куда фронт POST'ом отправляет лид.
# По умолчанию используется встроенная serverless-функция /api/lead,
# которая пересылает заявку в Telegram-бота. Оставьте пустым или
# задайте /api/lead. Если хотите отправлять лид на внешний webhook
# (например, n8n/Make/Tilda), укажите здесь его URL.
VITE_WEBHOOK_URL=/api/lead

# Секреты для serverless-функции api/lead.ts.
# Хранятся ТОЛЬКО на сервере (префикс VITE_ отсутствует — в бандл
# к браузеру они не попадают). Добавьте их в Vercel → Settings →
# Environment Variables.

# Токен Telegram-бота от @BotFather (строка вида "1234567890:AAH...")
TELEGRAM_BOT_TOKEN=

# ID вашего личного чата с ботом (число). Как получить — см.
# TELEGRAM-BOT-SETUP.md, шаг 2.
TELEGRAM_CHAT_ID=
